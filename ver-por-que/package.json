{
    "name": "ver-por-que",
    "version": "1.0.0",
    "type": "module",
    "description": "An interactive web-based tool for exploring how parquet files are structured. Pair with the python tool por-que, dump the file structure to JSON, and then load in this UI to see how the file is put together.",
    "source": "src/index.html",
    "scripts": {
        "generate": "node scripts/generate.mjs",
        "predev": "npm run generate",
        "dev": "parcel src/index.html",
        "prebuild": "npm run generate && node scripts/get-git-info.js",
        "build": "parcel build src/index.html --public-url ./",
        "pretest": "npm run generate",
        "test": "vitest run",
        "pretypecheck": "npm run generate",
        "typecheck": "tsc --noEmit",
        "prelint": "npm run generate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write src/ test/",
        "format:check": "prettier --check src/ test/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jkeifer/ver-por-que.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/jkeifer/ver-por-que/issues"
    },
    "homepage": "https://jkeifer.github.io/ver-por-que",
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@types/node": "^26.1.0",
        "ajv": "^8.20.0",
        "eslint": "^9.38.0",
        "globals": "^15.11.0",
        "json-schema-to-typescript": "^15.0.4",
        "parcel": "^2.16.0",
        "prettier": "^3.6.2",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.8.0",
        "vitest": "^2.1.4"
    }
}
